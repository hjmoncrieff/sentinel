  "construct_destinations": [
    "regime_vulnerability",
    "militarization",
    "security_fragmentation",
    "external_pressure",
    "economic_fragility"
  ],
  "implementation_status": {
    "event_layer": "current_primary_layer",
    "episode_layer": "not_yet_implemented",
    "process_layer": "not_yet_implemented"
  }
