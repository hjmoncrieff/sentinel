{
  "status": "private_internal_schema_scaffold",
  "description": "Internal scaffold for a future Process -> Episode -> Event aggregation layer in SENTINEL.",
  "hierarchy": [
    "process",
    "episode",
    "event"
  ],
  "event": {
    "role": "atomic_ingestion_and_publication_unit",
    "candidate_fields": [
      "event_id",
      "country",
      "event_date",
      "event_type",
      "event_subtype",
      "salience_intrinsic",
      "episode_id",
      "process_id",
      "episode_role",
      "process_relevance"
    ],
    "enum_fields": {
      "episode_role": [
        "trigger",
        "reinforcing",
        "turning_point",
        "background"
      ],
      "process_relevance": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "episode": {
    "role": "bounded_sequence_layer",
    "candidate_fields": [
      "episode_id",
      "country",
      "episode_type",
      "episode_title",
