{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel.local/schemas/canonical_event.schema.json",
  "title": "SENTINEL Canonical Event",
  "type": "object",
  "required": [
    "event_id",
    "event_date",
    "year",
    "month",
    "day",
    "country",
    "headline",
    "source_primary",
    "url_primary",
    "event_type",
    "salience",
    "confidence",
    "review_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "year": { "type": "integer", "minimum": 1900, "maximum": 2100 },
    "month": { "type": "integer", "minimum": 1, "maximum": 12 },
    "day": { "type": "integer", "minimum": 1, "maximum": 31 },
    "country": { "type": "string" },
    "subnational_location": { "type": ["string", "null"] },
    "location_text": { "type": ["string", "null"] },
    "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
    "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
    "headline": { "type": "string" },
    "source_primary": { "type": "string" },
    "source_all": {
      "type": "array",
      "items": { "type": "string" }
    },
    "url_primary": { "type": "string" },
    "url_all": {
      "type": "array",
      "items": { "type": "string" }
    },
    "language": { "type": ["string", "null"] },
    "event_type": { "type": "string" },
    "event_subtype": { "type": ["string", "null"] },
    "salience": { "type": "string", "enum": ["high", "medium", "low"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "summary": { "type": ["string", "null"] },
    "classification_reason": { "type": ["string", "null"] },
    "classification_rule_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actor_name", "actor_type"],
        "properties": {
          "actor_name": { "type": "string" },
          "actor_type": { "type": "string" },
          "actor_subtype": { "type": ["string", "null"] },
          "actor_country": { "type": ["string", "null"] },
          "actor_role_in_event": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "actor_primary_name": { "type": ["string", "null"] },
    "actor_primary_type": { "type": ["string", "null"] },
    "actor_secondary_name": { "type": ["string", "null"] },
    "actor_secondary_type": { "type": ["string", "null"] },
    "duplicate_group_id": { "type": ["string", "null"] },
    "duplicate_status": {
      "type": ["string", "null"],
      "enum": ["definite_duplicate", "possible_duplicate", "distinct", null]
    },
    "review_status": {
      "type": "string",
      "enum": ["auto", "flagged", "reviewed", "published", "rejected"]
    },
    "review_priority": {
      "type": ["string", "null"],
      "enum": ["high", "medium", "low", null]
    },
    "review_notes": { "type": ["string", "null"] },
    "reviewed_by": { "type": ["string", "null"] },
    "reviewed_at": { "type": ["string", "null"] },
    "provenance": {
      "type": "object",
      "properties": {
        "source_type": { "type": ["string", "null"] },
        "ingested_at": { "type": ["string", "null"] },
        "classification_model": { "type": ["string", "null"] },
        "merge_strategy": { "type": ["string", "null"] },
        "article_link_count": { "type": ["integer", "null"] },
        "article_record_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "linked_reports": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "article_id": { "type": ["string", "null"] },
              "article_rank": { "type": ["integer", "null"] },
              "report_role": { "type": ["string", "null"] },
              "source_name": { "type": ["string", "null"] },
              "url": { "type": ["string", "null"] },
              "link_domain": { "type": ["string", "null"] },
              "headline": { "type": ["string", "null"] },
              "source_type": { "type": ["string", "null"] },
              "linked_at": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stage": { "type": ["string", "null"] },
              "label": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] },
              "at": { "type": ["string", "null"] },
              "details": { "type": "object" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "published_at": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
