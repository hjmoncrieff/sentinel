{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel.local/schemas/qa_flag.schema.json",
  "title": "SENTINEL QA Flag",
  "type": "object",
  "required": ["flag_id", "event_id", "severity", "code", "message"],
  "properties": {
    "flag_id": { "type": "string" },
    "event_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["high", "medium", "low"] },
    "code": { "type": "string" },
    "message": { "type": "string" },
    "details": { "type": ["object", "null"] }
  },
  "additionalProperties": false
}
